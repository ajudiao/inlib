{% extends 'layouts/admin.twig' %}

{% block title %}Dashboard - INLIB Admin{% endblock %}

{% block styles %}
  <script src="https://cdn.jsdelivr.net/npm/chart.js@3.9.1/dist/chart.min.js"></script>
  <style>
    .charts-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
      gap: 2rem;
      margin: 2rem 0;
    }

    .chart-container {
      background: var(--white);
      padding: 1.5rem;
      border-radius: var(--border-radius);
      box-shadow: var(--box-shadow);
    }

    .chart-title {
      font-size: 1.1rem;
      font-weight: 600;
      color: var(--primary-dark);
      margin-bottom: 1rem;
    }

    .chart-wrapper {
      position: relative;
      height: 300px;
    }

    @media (max-width: 1200px) {
      .charts-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
{% endblock %}

{% block content %}
      <div class="admin-header">
        <h1>Dashboard</h1>
        <div class="admin-header-actions">
          <button class="btn-admin btn-admin-primary" onclick="window.location.href='{{ url('/admin/livros/adicionar') }}'">
            ✚ Novo Livro
          </button>
        </div>
      </div>

      <!-- Stats Grid -->
      <div class="dashboard-grid">
        <div class="stat-card-admin">
          <div class="stat-card-admin-header">
            <div class="stat-card-admin-label">Total de Livros</div>
            <div class="stat-card-admin-icon">▢</div>
          </div>
          <div class="stat-card-admin-value" id="stat-total-books">12</div>
          <div class="stat-card-admin-change">+3 este mês</div>
        </div>

        <div class="stat-card-admin">
          <div class="stat-card-admin-header">
            <div class="stat-card-admin-label">Categorias</div>
            <div class="stat-card-admin-icon">◇</div>
          </div>
          <div class="stat-card-admin-value" id="stat-categories">9</div>
          <div class="stat-card-admin-change">Organizadas</div>
        </div>

        <div class="stat-card-admin">
          <div class="stat-card-admin-header">
            <div class="stat-card-admin-label">Usuários Ativos</div>
            <div class="stat-card-admin-icon">⟡</div>
          </div>
          <div class="stat-card-admin-value" id="stat-users">4</div>
          <div class="stat-card-admin-change">+1 esta semana</div>
        </div>

        <div class="stat-card-admin">
          <div class="stat-card-admin-header">
            <div class="stat-card-admin-label">Empréstimos Ativos</div>
            <div class="stat-card-admin-icon">◈</div>
          </div>
          <div class="stat-card-admin-value" id="stat-loans">127</div>
          <div class="stat-card-admin-change">+15 esta semana</div>
        </div>
      </div>

      <!-- Charts Section -->
      <div style="margin-top: 3rem;">
        <h2 style="color: var(--primary-dark); margin-bottom: 1.5rem;">Análise e Relatórios</h2>
        <div class="charts-grid">
          <div class="chart-container">
            <div class="chart-title">Livros por Categoria</div>
            <div class="chart-wrapper">
              <canvas id="categoryChart"></canvas>
            </div>
          </div>

          <div class="chart-container">
            <div class="chart-title">Distribuição de Empréstimos</div>
            <div class="chart-wrapper">
              <canvas id="loansChart"></canvas>
            </div>
          </div>

          <div class="chart-container">
            <div class="chart-title">Crescimento de Acervo</div>
            <div class="chart-wrapper">
              <canvas id="growthChart"></canvas>
            </div>
          </div>

          <div class="chart-container">
            <div class="chart-title">Status de Livros</div>
            <div class="chart-wrapper">
              <canvas id="statusChart"></canvas>
            </div>
          </div>
        </div>
      </div>

      <!-- Recent Books -->
      <section>
        <div class="admin-header" style="margin-bottom: 1.5rem;">
          <h2 style="margin: 0; color: var(--primary-dark);">Livros Recentes</h2>
          <a href="{{ url('/admin/livros') }}" class="btn-admin btn-admin-secondary">Ver Todos →</a>
        </div>

        <div class="table-container">
          <div class="table-responsive">
            <table>
              <thead>
                <tr>
                  <th>Livro</th>
                  <th>Autor</th>
                  <th>Categoria</th>
                  <th>Data Adição</th>
                  <th>Status</th>
                  <th>Ações</th>
                </tr>
              </thead>
              <tbody id="recent-books-table">
                <!-- Preenchido por JavaScript -->
              </tbody>
            </table>
          </div>
        </div>
      </section>

      <!-- Recent Activities -->
      <section style="margin-top: 3rem;">
        <div class="admin-header" style="margin-bottom: 1.5rem;">
          <h2 style="margin: 0; color: var(--primary-dark);">Atividades Recentes</h2>
        </div>

        <div class="table-container">
          <div class="table-responsive">
            <table>
              <thead>
                <tr>
                  <th>Ação</th>
                  <th>Descrição</th>
                  <th>Data</th>
                  <th>Usuário</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td>✅ Livro Adicionado</td>
                  <td>Tesouro da Montanha foi adicionado ao catálogo</td>
                  <td>15 de Jan, 2024</td>
                  <td>João Silva</td>
                </tr>
                <tr>
                  <td>📝 Livro Editado</td>
                  <td>Informações de "1984" foram atualizadas</td>
                  <td>14 de Jan, 2024</td>
                  <td>João Silva</td>
                </tr>
                <tr>
                  <td>👤 Usuário Criado</td>
                  <td>Novo usuário Ana Costa foi registrado</td>
                  <td>13 de Jan, 2024</td>
                  <td>Sistema</td>
                </tr>
                <tr>
                  <td>🔄 Categoria Criada</td>
                  <td>Nova categoria "Educação" foi criada</td>
                  <td>10 de Jan, 2024</td>
                  <td>João Silva</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </section>

      <!-- Quick Actions -->
      <section style="margin-top: 3rem; margin-bottom: 2rem;">
        <h2 style="color: var(--primary-dark); margin-bottom: 1.5rem;">Ações Rápidas</h2>
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem;">
          <a href="adicionar-livro.html" class="btn-admin btn-admin-primary" style="text-align: center; padding: 1rem;">
            ➕ Adicionar Livro
          </a>
          <a href="categorias.html" class="btn-admin btn-admin-secondary" style="text-align: center; padding: 1rem;">
            📁 Gerenciar Categorias
          </a>
          <a href="usuarios.html" class="btn-admin btn-admin-secondary" style="text-align: center; padding: 1rem;">
            👥 Gerenciar Usuários
          </a>
          <a href="configuracoes.html" class="btn-admin btn-admin-secondary" style="text-align: center; padding: 1rem;">
            ⚙️ Configurações
          </a>
        </div>
      </section>

  {% endblock %}

  {% block scripts %}
  <script>
    let categoryChart, loansChart, growthChart, statusChart;

    function initCharts() {
      const books = getBooks();
      const categories = getCategories();
      
      // Prepare data for category chart
      const categoryLabels = categories.map(c => c.name);
      const categoryData = categories.map(c => books.filter(b => b.category === c.name).length);
      
      const categoryColors = [
        '#0066cc', '#00a6ff', '#006699', '#0099ff',
        '#0055aa', '#0088dd', '#004488', '#0077bb', '#0066ff'
      ];

      // Category Chart
      const categoryCtx = document.getElementById('categoryChart');
      if (categoryCtx) {
        categoryChart = new Chart(categoryCtx, {
          type: 'bar',
          data: {
            labels: categoryLabels,
            datasets: [{
              label: 'Quantidade de Livros',
              data: categoryData,
              backgroundColor: categoryColors,
              borderRadius: 5,
              borderSkipped: false
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            indexAxis: 'y',
            plugins: {
              legend: { display: false }
            },
            scales: {
              x: {
                beginAtZero: true,
                max: Math.max(...categoryData) + 2
              }
            }
          }
        });
      }

      // Loans Chart (Pie)
      const loansCtx = document.getElementById('loansChart');
      if (loansCtx) {
        loansChart = new Chart(loansCtx, {
          type: 'doughnut',
          data: {
            labels: ['Empréstimos Ativos', 'Disponíveis', 'Em Processamento'],
            datasets: [{
              data: [127, 245, 28],
              backgroundColor: ['#0066cc', '#10b981', '#f59e0b'],
              borderColor: '#fff',
              borderWidth: 2
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
              legend: { position: 'bottom' }
            }
          }
        });
      }

      // Growth Chart (Line)
      const growthCtx = document.getElementById('growthChart');
      if (growthCtx) {
        growthChart = new Chart(growthCtx, {
          type: 'line',
          data: {
            labels: ['Jan', 'Fev', 'Mar', 'Abr', 'Mai', 'Jun'],
            datasets: [{
              label: 'Livros Adicionados',
              data: [8, 12, 15, 18, 20, 22],
              borderColor: '#0066cc',
              backgroundColor: 'rgba(0, 102, 204, 0.1)',
              borderWidth: 3,
              fill: true,
              tension: 0.4,
              pointBackgroundColor: '#0066cc',
              pointRadius: 5,
              pointHoverRadius: 7
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
              legend: { display: false }
            },
            scales: {
              y: { beginAtZero: true }
            }
          }
        });
      }

      // Status Chart (Horizontal Bar)
      const statusCtx = document.getElementById('statusChart');
      if (statusCtx) {
        statusChart = new Chart(statusCtx, {
          type: 'bar',
          data: {
            labels: ['Disponíveis', 'Em Empréstimo', 'Manutenção', 'Reservados'],
            datasets: [{
              label: 'Quantidade',
              data: [245, 127, 18, 30],
              backgroundColor: ['#10b981', '#0066cc', '#f59e0b', '#ef4444'],
              borderRadius: 5,
              borderSkipped: false
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            indexAxis: 'y',
            plugins: {
              legend: { display: false }
            },
            scales: {
              x: { beginAtZero: true }
            }
          }
        });
      }
    }

    function initDashboard() {
      const admin = getAdminUser();
      const stats = getStats();
      const books = getBooks();

      // Update admin info
      document.getElementById('admin-name').textContent = admin.name;

      // Update stats
      document.getElementById('stat-total-books').textContent = stats.totalBooks;
      document.getElementById('stat-categories').textContent = stats.totalCategories;
      document.getElementById('stat-users').textContent = stats.totalUsers;
      document.getElementById('stat-loans').textContent = stats.loans;

      // Load recent books
      const recentBooks = books.slice(0, 5);
      const tableBody = document.getElementById('recent-books-table');
      
      tableBody.innerHTML = recentBooks.map(book => `
        <tr>
          <td><strong>${book.title}</strong></td>
          <td>${book.author}</td>
          <td>${book.category}</td>
          <td>${book.year}</td>
          <td><span style="background-color: #10b981; color: white; padding: 0.25rem 0.75rem; border-radius: 20px; font-size: 0.85rem;">Ativo</span></td>
          <td>
            <div class="table-actions">
              <button class="table-action-btn action-edit" onclick="window.location.href='{{ url('/admin/livros/editar') }}/${book.id}'">Editar</button>
              <button class="table-action-btn action-delete" onclick="deleteBook(${book.id})">Excluir</button>
            </div>
          </td>
        </tr>
      `).join('');

      // Initialize charts
      initCharts();
    }

    function handleLogout() {
      if (confirm('Tem certeza que deseja sair?')) {
        removeStorage('loggedIn');
        removeStorage('user');
        showNotification('Você foi desconectado', 'info');
        setTimeout(() => {
          window.location.href = '{{ url('/') }}';
        }, 1000);
      }
    }

    function deleteBook(bookId) {
      confirmAction('Tem certeza que deseja excluir este livro?', () => {
        showNotification('Livro excluído com sucesso (simulado)', 'success');
      });
    }

    document.addEventListener('DOMContentLoaded', initDashboard);
  </script>
  {% endblock %}
