{% extends 'layouts/admin.twig' %}

{% block title %}Dashboard - INLIB Admin{% endblock %}

{% block styles %}
  <script src="https://cdn.jsdelivr.net/npm/chart.js@3.9.1/dist/chart.min.js"></script>
  <style>
    .charts-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
      gap: 2rem;
      margin: 2rem 0;
    }

    .chart-container {
      background: var(--white);
      padding: 1.5rem;
      border-radius: var(--border-radius);
      box-shadow: var(--box-shadow);
    }

    .chart-title {
      font-size: 1.1rem;
      font-weight: 600;
      color: var(--primary-dark);
      margin-bottom: 1rem;
    }

    .chart-wrapper {
      position: relative;
      height: 300px;
    }

    @media (max-width: 1200px) {
      .charts-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
{% endblock %}

{% block content %}
  <div class="admin-header">
    <div>
      <h1>Dashboard</h1>
      <p style="margin: 0.5rem 0 0; color: var(--text-secondary); max-width: 640px;">Resumo rápido das métricas essenciais com dados vindos diretamente do banco.</p>
    </div>
    <div class="admin-header-actions">
      <a class="btn-admin btn-admin-primary" href="{{ url('/admin/livros/adicionar-livro') }}">✚ Novo Livro</a>
    </div>
  </div>

  <div class="dashboard-grid">
    <div class="stat-card-admin">
      <div class="stat-card-admin-header">
        <div class="stat-card-admin-label">Total de Livros</div>
        <div class="stat-card-admin-icon">▢</div>
      </div>
      <div class="stat-card-admin-value">{{ totalLivros }}</div>
      <div class="stat-card-admin-change">{{ livrosAtivos }} ativos</div>
    </div>

    <div class="stat-card-admin">
      <div class="stat-card-admin-header">
        <div class="stat-card-admin-label">Categorias</div>
        <div class="stat-card-admin-icon">◇</div>
      </div>
      <div class="stat-card-admin-value">{{ totalCategorias }}</div>
      <div class="stat-card-admin-change">Cadastradas</div>
    </div>

    <div class="stat-card-admin">
      <div class="stat-card-admin-header">
        <div class="stat-card-admin-label">Usuários Ativos</div>
        <div class="stat-card-admin-icon">⟡</div>
      </div>
      <div class="stat-card-admin-value">{{ usuariosAtivos }}</div>
      <div class="stat-card-admin-change">No sistema</div>
    </div>

    <div class="stat-card-admin">
      <div class="stat-card-admin-header">
        <div class="stat-card-admin-label">Status dos Livros</div>
        <div class="stat-card-admin-icon">◈</div>
      </div>
      <div class="stat-card-admin-value">{{ livrosAtivos }}/{{ totalLivros }}</div>
      <div class="stat-card-admin-change">Ativos / Total</div>
    </div>
  </div>

  <div style="margin-top: 3rem;">
    <h2 style="color: var(--primary-dark); margin-bottom: 1rem;">Visão Rápida</h2>
    <div class="charts-grid">
      <div class="chart-container">
        <div class="chart-title">Livros por Categoria</div>
        <div class="chart-wrapper">
          <canvas id="categoryChart"></canvas>
        </div>
      </div>

      <div class="chart-container">
        <div class="chart-title">Status dos Livros</div>
        <div class="chart-wrapper">
          <canvas id="statusChart"></canvas>
        </div>
      </div>
    </div>
  </div>
{% endblock %}

{% block scripts %}
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const categoryLabels = {{ categoriesSummary|map(item => item.nome)|json_encode|raw }};
      const categoryData = {{ categoriesSummary|map(item => item.livros_count)|json_encode|raw }};

      const categoryCtx = document.getElementById('categoryChart');
      if (categoryCtx) {
        new Chart(categoryCtx, {
          type: 'bar',
          data: {
            labels: categoryLabels,
            datasets: [{
              label: 'Quantidade de Livros',
              data: categoryData,
              backgroundColor: ['#0066cc', '#00a6ff', '#006699', '#0099ff', '#0055aa', '#0088dd', '#004488', '#0077bb', '#0066ff'],
              borderRadius: 5,
              borderSkipped: false
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            indexAxis: 'y',
            plugins: { legend: { display: false } },
            scales: {
              x: { beginAtZero: true, max: Math.max(...categoryData, 1) + 1 }
            }
          }
        });
      }

      const statusCtx = document.getElementById('statusChart');
      if (statusCtx) {
        new Chart(statusCtx, {
          type: 'doughnut',
          data: {
            labels: ['Ativos', 'Inativos'],
            datasets: [{
              data: [{{ livrosAtivos }}, {{ livrosInativos }}],
              backgroundColor: ['#10b981', '#f59e0b'],
              borderColor: '#fff',
              borderWidth: 2
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { position: 'bottom' } }
          }
        });
      }
    });
  </script>
{% endblock %}
