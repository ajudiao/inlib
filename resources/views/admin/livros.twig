{% extends 'layouts/admin.twig' %}

{% block title %}Livros - INLIB Admin{% endblock %}

{% block content %}
      <div class="admin-header">
        <h1>Gestão de Livros</h1>
        <div class="admin-header-actions">
          <a href="adicionar-livro.html" class="btn-admin btn-admin-primary">➕ Novo Livro</a>
        </div>
      </div>

      <div class="table-container">
        <div class="table-responsive">
          <table>
            <thead>
              <tr>
                <th>Capa</th>
                <th>Título</th>
                <th>Autor</th>
                <th>Categoria</th>
                <th>Ano</th>
                <th>Páginas</th>
                <th>Ações</th>
              </tr>
            </thead>
            <tbody id="books-list-table">
              <!-- Preenchido por JavaScript -->
            </tbody>
          </table>
        </div>
      </div>

  <script src="../../assets/js/data.js"></script>
  <script src="../../assets/js/main.js"></script>
  <script>
    function loadBooks() {
      const books = getBooks();
      const tableBody = document.getElementById('books-list-table');
      
      tableBody.innerHTML = books.map(book => `
        <tr>
          <td><img src="${book.cover}" alt="${book.title}" style="width: 40px; height: 50px; object-fit: cover; border-radius: 4px;"></td>
          <td><strong>${book.title}</strong></td>
          <td>${book.author}</td>
          <td>${book.category}</td>
          <td>${book.year}</td>
          <td>${book.pages}</td>
          <td>
            <div class="table-actions">
              <button class="table-action-btn action-view" onclick="viewBook(${book.id})">Visualizar</button>
              <button class="table-action-btn action-edit" onclick="window.location.href='editar-livro.html?id=${book.id}'">Editar</button>
              <button class="table-action-btn action-delete" onclick="deleteBook(${book.id})">Excluir</button>
            </div>
          </td>
        </tr>
      `).join('');
    }

    function viewBook(bookId) {
      window.location.href = `../../views/public/livro.html?id=${bookId}`;
    }

    function deleteBook(bookId) {
      confirmAction('Tem certeza que deseja excluir este livro?', () => {
        showNotification('Livro excluído com sucesso (simulado)', 'success');
      });
    }

    function handleLogout() {
      if (confirm('Tem certeza que deseja sair?')) {
        removeStorage('loggedIn');
        removeStorage('user');
        window.location.href = '../../views/public/index.html';
      }
    }

    loadBooks();
  </script>
{% endblock %}
