{% extends 'layouts/admin.twig' %}

{% block title %}Livros - INLIB Admin{% endblock %}

{% block content %}
  <div class="admin-header">
    <h1>Gestão de Livros</h1>
    <div class="admin-header-actions">
      <a href="{{ url('/admin/livros/adicionar-livro') }}" class="btn-admin btn-admin-primary"><i class="fas fa-plus-circle"></i> Novo Livro</a>
    </div>
  </div>

  {% if flash %}
    <div class="alert {% if flash.type == 'success' %}alert-success{% else %}alert-error{% endif %}">
      {{ flash.message }}
    </div>
  {% endif %}

  <div class="admin-toolbar">
    <form method="get" action="{{ url('/admin/livros') }}" class="search-form">
      <input type="text" name="q" value="{{ searchTerm|default('') }}" placeholder="Pesquisar por título, autor, editora ou categoria">
      <button type="submit" class="btn-admin btn-admin-primary">Pesquisar</button>
      {% if searchTerm %}
        <a href="{{ url('/admin/livros') }}" class="btn-admin btn-admin-secondary">Limpar</a>
      {% endif %}
    </form>
  </div>

  <div class="table-container">
    <div class="table-responsive">
      <table>
        <thead>
          <tr>
            <th>Capa</th>
            <th>Título</th>
            <th>Autor</th>
            <th>Categoria</th>
            <th>Ano</th>
            <th>Estoque</th>
            <th>Status</th>
            <th>Ações</th>
          </tr>
        </thead>
        <tbody>
          {% for livro in livros %}
            <tr>
              <td>
                {% if livro.capa %}
                  <img src="{{ livro.capa }}" alt="{{ livro.titulo }}" style="width: 40px; height: 50px; object-fit: cover; border-radius: 4px;">
                {% else %}
                  <div style="width: 40px; height: 50px; display: flex; align-items: center; justify-content: center; border-radius: 4px; background: #f3e0b7; color: #7a6241; font-size: 1.2rem;"><i class="fas fa-book"></i></div>
                {% endif %}
              </td>
              <td><strong>{{ livro.titulo }}</strong></td>
              <td>{{ livro.autor }}</td>
              <td>{{ livro.categoriaNome ?: 'Sem categoria' }}</td>
              <td>{{ livro.anoPublicacao ?: '-' }}</td>
              <td>{{ livro.quantidadeEstoque }}</td>
              <td>
                {% if livro.ativo %}
                  <span style="background-color: #10b981; color: white; padding: 0.25rem 0.75rem; border-radius: 20px; font-size: 0.85rem;">Ativo</span>
                {% else %}
                  <span style="background-color: #ef4444; color: white; padding: 0.25rem 0.75rem; border-radius: 20px; font-size: 0.85rem;">Inativo</span>
                {% endif %}
              </td>
              <td>
                <div class="table-actions">
                  <a href="{{ url('/ver_livro/' ~ livro.id) }}" class="table-action-btn action-view">Visualizar</a>
                  <a href="{{ url('/admin/livros/editar/' ~ livro.id) }}" class="table-action-btn action-edit">Editar</a>
                  <form method="post" action="{{ url('/admin/livros/apagar/' ~ livro.id) }}" onsubmit="return confirm('Tem a certeza que deseja apagar este livro?');">
                    <button type="submit" class="table-action-btn action-delete">Apagar</button>
                  </form>
                </div>
              </td>
            </tr>
          {% else %}
            <tr>
              <td colspan="8" style="text-align: center; padding: 2rem;">Nenhum livro encontrado.</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
{% endblock %}
