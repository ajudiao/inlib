{% extends 'layouts/admin.twig' %}

{% block title %}Livros - INLIB Admin{% endblock %}

{% block content %}
  <div class="admin-header">
    <h1>Gestão de Livros</h1>
    <div class="admin-header-actions">
      <a href="{{ url('/admin/livros/adicionar-livro') }}" class="btn-admin btn-admin-primary">➕ Novo Livro</a>
    </div>
  </div>

  {% if flash %}
    <div style="margin-bottom: 1rem; padding: 0.9rem 1rem; border-radius: 6px; {% if flash.type == 'success' %}background: #d4edda; color: #155724; border: 1px solid #c3e6cb;{% else %}background: #f8d7da; color: #721c24; border: 1px solid #f5c6cb;{% endif %}">
      {{ flash.message }}
    </div>
  {% endif %}

  <div class="table-container">
    <div class="table-responsive">
      <table>
        <thead>
          <tr>
            <th>Capa</th>
            <th>Título</th>
            <th>Autor</th>
            <th>Categoria</th>
            <th>Ano</th>
            <th>Estoque</th>
            <th>Status</th>
            <th>Ações</th>
          </tr>
        </thead>
        <tbody>
          {% for livro in livros %}
            <tr>
              <td>
                {% if livro.capa %}
                  <img src="{{ livro.capa }}" alt="{{ livro.titulo }}" style="width: 40px; height: 50px; object-fit: cover; border-radius: 4px;">
                {% else %}
                  <div style="width: 40px; height: 50px; display: flex; align-items: center; justify-content: center; border-radius: 4px; background: #e5eef8; color: #0056b3; font-size: 1.2rem;">📖</div>
                {% endif %}
              </td>
              <td><strong>{{ livro.titulo }}</strong></td>
              <td>{{ livro.autor }}</td>
              <td>{{ livro.categoriaNome ?: 'Sem categoria' }}</td>
              <td>{{ livro.anoPublicacao ?: '-' }}</td>
              <td>{{ livro.quantidadeEstoque }}</td>
              <td>
                {% if livro.ativo %}
                  <span style="background-color: #10b981; color: white; padding: 0.25rem 0.75rem; border-radius: 20px; font-size: 0.85rem;">Ativo</span>
                {% else %}
                  <span style="background-color: #ef4444; color: white; padding: 0.25rem 0.75rem; border-radius: 20px; font-size: 0.85rem;">Inativo</span>
                {% endif %}
              </td>
              <td>
                <div class="table-actions">
                  <a href="{{ url('/ver_livro/' ~ livro.id) }}" class="table-action-btn action-view">Visualizar</a>
                  <a href="{{ url('/admin/livros/editar/' ~ livro.id) }}" class="table-action-btn action-edit">Editar</a>
                </div>
              </td>
            </tr>
          {% else %}
            <tr>
              <td colspan="8" style="text-align: center; padding: 2rem;">Nenhum livro encontrado.</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
{% endblock %}
