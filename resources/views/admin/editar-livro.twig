{% extends 'layouts/admin.twig' %}

{% block title %}Editar Livro - INLIB Admin{% endblock %}

{% block content %}
  <div class="admin-header">
    <h1>Editar Livro</h1>
    <a href="{{ url('/admin/livros') }}" class="btn-admin btn-admin-secondary">Voltar à lista</a>
  </div>

  {% if flash %}
    <div class="alert {% if flash.type == 'success' %}alert-success{% else %}alert-error{% endif %}">
      {{ flash.message }}
    </div>
  {% endif %}

  <div class="form-container">
    <div class="form-card">
      <form action="{{ url('/admin/livros/editar/' ~ livro.id) }}" method="POST" enctype="multipart/form-data">
        <div class="form-section">
          <div class="form-section-header">
            <h3 class="form-section-title">Dados do Livro</h3>
          </div>
          <div class="form-grid">
            <div class="form-group">
              <label for="titulo">Título *</label>
              <input type="text" id="titulo" name="titulo" value="{{ livro.titulo }}" required>
            </div>
            <div class="form-group">
              <label for="autor">Autor *</label>
              <input type="text" id="autor" name="autor" value="{{ livro.autor }}" required>
            </div>
            <div class="form-group">
              <label for="capa">Nova capa</label>
              <input type="file" id="capa" name="capa" accept="image/jpeg,image/png,image/webp">
              <small>Deixe em branco para manter a capa atual.</small>
            </div>
            <div class="form-group">
              <label for="url_livro">Novo PDF</label>
              <input type="file" id="url_livro" name="url_livro" accept="application/pdf">
              <small>Deixe em branco para manter o PDF atual.</small>
            </div>
          </div>
        </div>

        <div class="form-section">
          <div class="form-section-header">
            <h3 class="form-section-title">Informações Complementares</h3>
          </div>
          <div class="form-grid">
            <div class="form-group">
              <label for="editora">Editora *</label>
              <input type="text" id="editora" name="editora" value="{{ livro.editora|default('') }}" required>
            </div>
            <div class="form-group">
              <label for="categoria_id">Categoria *</label>
              <select id="categoria_id" name="categoria_id" required>
                <option value="">Selecione uma categoria</option>
                {% for category in categories %}
                  <option value="{{ category.id }}" {% if livro.categoriaId == category.id %}selected{% endif %}>{{ category.nome }}</option>
                {% endfor %}
              </select>
            </div>
            <div class="form-group">
              <label for="ano_publicacao">Ano de Publicação *</label>
              <input type="number" id="ano_publicacao" name="ano_publicacao" min="1400" max="2099" value="{{ livro.anoPublicacao|default('') }}" required>
            </div>
            <div class="form-group">
              <label for="edicao">Edição *</label>
              <input type="text" id="edicao" name="edicao" value="{{ livro.edicao|default('') }}" required>
            </div>
            <div class="form-group">
              <label for="isbn">ISBN</label>
              <input type="text" id="isbn" name="isbn" value="{{ livro.isbn|default('') }}">
            </div>
            <div class="form-group">
              <label for="quantidade_estoque">Quantidade em Estoque *</label>
              <input type="number" id="quantidade_estoque" name="quantidade_estoque" min="0" value="{{ livro.quantidadeEstoque }}" required>
            </div>
          </div>
        </div>

        <div class="form-section">
          <div class="form-section-header">
            <h3 class="form-section-title">Sinopse</h3>
          </div>
          <div class="form-group">
            <label for="sinopse">Sinopse *</label>
            <textarea id="sinopse" name="sinopse" rows="6" required>{{ livro.sinopse|default('') }}</textarea>
          </div>
        </div>

        <div class="form-section">
          <div class="form-section-header">
            <h3 class="form-section-title">Status</h3>
          </div>
          <div class="form-group form-switch">
            <label for="ativo">Ativo</label>
            <input type="checkbox" id="ativo" name="ativo" {% if livro.ativo %}checked{% endif %}>
          </div>
        </div>

        <div class="form-actions">
          <a href="{{ url('/admin/livros') }}" class="btn-admin btn-admin-secondary">Cancelar</a>
          <button type="submit" class="btn-admin btn-admin-primary">Salvar Alterações</button>
        </div>
      </form>
    </div>
  </div>
{% endblock %}
