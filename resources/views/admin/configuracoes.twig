{% extends 'layouts/admin.twig' %}

{% block title %}Configurações - INLIB Admin{% endblock %}

{% block content %}
      <div class="admin-header">
        <h1>Configurações do Sistema</h1>
      </div>

      <div class="form-container">
        <h2 class="form-title">Informações da Biblioteca</h2>

        {% if flash is defined and flash %}
          <div class="alert alert-success">{{ flash.message }}</div>
        {% endif %}

        <form id="settings-form" method="post" action="{{ url('/admin/configuracoes') }}">
          <div class="form-section">
            <h3 class="form-section-title">Dados Básicos</h3>
            <div class="form-grid">
              <div class="form-group">
                <label for="lib-name">Nome da Biblioteca</label>
                <input type="text" id="lib-name" name="nome" value="{{ settings.nome|default('INLIB - Instic Library') }}">
              </div>
              <div class="form-group">
                <label for="lib-email">Email de Contato</label>
                <input type="email" id="lib-email" name="email" value="{{ settings.email|default('contato@inlib.com') }}">
              </div>
            </div>
          </div>

          <div class="form-section">
            <h3 class="form-section-title">Informações de Contato</h3>
            <div class="form-grid">
              <div class="form-group">
                <label for="lib-phone">Telefone</label>
                <input type="text" id="lib-phone" name="contato" value="{{ settings.contato|default('(11) 3000-0000') }}">
              </div>
              <div class="form-group">
                <label for="lib-address">Endereço</label>
                <input type="text" id="lib-address" name="endereco" value="{{ settings.endereco|default('Av. Paulista, 1000 - São Paulo, SP') }}">
              </div>
            </div>
          </div>
         
          <div class="form-actions">
            <button type="submit" class="btn-admin btn-admin-primary">Salvar Configurações</button>
          </div>
        </form>
      </div>

      <div class="form-container" style="margin-top: 2rem;">
        <h2 class="form-title">Sistema</h2>
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem;">
          <div style="padding: 1rem; background-color: var(--gray-light); border-radius: var(--border-radius);">
            <div style="font-weight: 600; margin-bottom: 0.5rem;">Versão</div>
            <div style="color: var(--text-secondary);">1.0.0</div>
          </div>
          <div style="padding: 1rem; background-color: var(--gray-light); border-radius: var(--border-radius);">
            <div style="font-weight: 600; margin-bottom: 0.5rem;">Última Atualização</div>
            <div style="color: var(--text-secondary);">15 de Janeiro de 2024</div>
          </div>
          <div style="padding: 1rem; background-color: var(--gray-light); border-radius: var(--border-radius);">
            <div style="font-weight: 600; margin-bottom: 0.5rem;">Status</div>
            <div style="color: #10b981; font-weight: 600;"><i class="fas fa-check-circle"></i> Online</div>
          </div>
        </div>
      </div>

  <script src="../../assets/js/data.js"></script>
  <script src="../../assets/js/main.js"></script>
{% endblock %}
