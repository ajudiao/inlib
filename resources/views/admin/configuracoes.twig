{% extends 'layouts/admin.twig' %}

{% block title %}Configurações - INLIB Admin{% endblock %}

{% block content %}
      <div class="admin-header">
        <h1>Configurações do Sistema</h1>
      </div>

      <div class="form-container">
        <h2 class="form-title">Informações da Biblioteca</h2>

        <form id="settings-form" onsubmit="handleSettings(event)">
          <div class="form-section">
            <h3 class="form-section-title">Dados Básicos</h3>
            <div class="form-grid">
              <div class="form-group">
                <label for="lib-name">Nome da Biblioteca</label>
                <input type="text" id="lib-name" value="INLIB - Instic Library">
              </div>
              <div class="form-group">
                <label for="lib-email">Email de Contato</label>
                <input type="email" id="lib-email" value="contato@inlib.com">
              </div>
            </div>
          </div>

          <div class="form-section">
            <h3 class="form-section-title">Informações de Contato</h3>
            <div class="form-grid">
              <div class="form-group">
                <label for="lib-phone">Telefone</label>
                <input type="text" id="lib-phone" value="(11) 3000-0000">
              </div>
              <div class="form-group">
                <label for="lib-address">Endereço</label>
                <input type="text" id="lib-address" value="Av. Paulista, 1000 - São Paulo, SP">
              </div>
            </div>
          </div>

          <div class="form-section">
            <h3 class="form-section-title">Redes Sociais</h3>
            <div class="form-grid">
              <div class="form-group">
                <label for="social-facebook">Facebook</label>
                <input type="url" id="social-facebook" placeholder="https://facebook.com/...">
              </div>
              <div class="form-group">
                <label for="social-instagram">Instagram</label>
                <input type="url" id="social-instagram" placeholder="https://instagram.com/...">
              </div>
              <div class="form-group">
                <label for="social-twitter">Twitter/X</label>
                <input type="url" id="social-twitter" placeholder="https://twitter.com/...">
              </div>
              <div class="form-group">
                <label for="social-linkedin">LinkedIn</label>
                <input type="url" id="social-linkedin" placeholder="https://linkedin.com/...">
              </div>
            </div>
          </div>

          <div class="form-section">
            <h3 class="form-section-title">Configurações de Privacidade</h3>
            <div class="form-group">
              <label style="display: flex; align-items: center; gap: 0.5rem; font-weight: normal;">
                <input type="checkbox" checked> Ativar registro de novos usuários
              </label>
            </div>
            <div class="form-group">
              <label style="display: flex; align-items: center; gap: 0.5rem; font-weight: normal;">
                <input type="checkbox" checked> Permitir downloads de PDFs
              </label>
            </div>
          </div>

          <div class="form-actions">
            <button type="submit" class="btn-admin btn-admin-primary">Salvar Configurações</button>
          </div>
        </form>
      </div>

      <div class="form-container" style="margin-top: 2rem;">
        <h2 class="form-title">Sistema</h2>
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem;">
          <div style="padding: 1rem; background-color: var(--gray-light); border-radius: var(--border-radius);">
            <div style="font-weight: 600; margin-bottom: 0.5rem;">Versão</div>
            <div style="color: var(--text-secondary);">1.0.0</div>
          </div>
          <div style="padding: 1rem; background-color: var(--gray-light); border-radius: var(--border-radius);">
            <div style="font-weight: 600; margin-bottom: 0.5rem;">Última Atualização</div>
            <div style="color: var(--text-secondary);">15 de Janeiro de 2024</div>
          </div>
          <div style="padding: 1rem; background-color: var(--gray-light); border-radius: var(--border-radius);">
            <div style="font-weight: 600; margin-bottom: 0.5rem;">Status</div>
            <div style="color: #10b981; font-weight: 600;"><i class="fas fa-check-circle"></i> Online</div>
          </div>
        </div>
      </div>

  <script src="../../assets/js/data.js"></script>
  <script src="../../assets/js/main.js"></script>
  <script>
    function handleSettings(event) {
      event.preventDefault();
      showNotification('Configurações salvas com sucesso!', 'success');
    }
    function handleLogout() { if (confirm('Sair?')) { removeStorage('loggedIn'); window.location.href = '/'; } }
  </script>
{% endblock %}
