{% extends 'layouts/admin.twig' %}

{% block title %}Usuários - INLIB Admin{% endblock %}

{% block content %}
  <div class="admin-header">
    <h1>Gestão de Usuários</h1>
  </div>

  <div class="admin-header-actions" style="margin-bottom: 1rem;">
    <a href="{{ url('/admin/usuarios/adicionar-usuario') }}" class="btn-admin btn-admin-primary">➕ Novo Usuário</a>
  </div>

  {% if flash %}
    <div style="margin-bottom: 1rem; padding: 0.9rem 1rem; border-radius: 6px; {% if flash.type == 'success' %}background: #d4edda; color: #155724; border: 1px solid #c3e6cb;{% else %}background: #f8d7da; color: #721c24; border: 1px solid #f5c6cb;{% endif %}">
      {{ flash.message }}
    </div>
  {% endif %}

  <div class="table-container">
    <table>
      <thead>
        <tr>
          <th>Nome</th>
          <th>Email</th>
          <th>Perfil</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody>
        {% for usuario in usuarios %}
          <tr>
            <td><strong>{{ usuario.nome }}</strong></td>
            <td>{{ usuario.email }}</td>
            <td>{{ usuario.perfil }}</td>
            <td>
              {% if usuario.ativo %}
                <span style="background-color: #10b981; color: white; padding: 0.25rem 0.75rem; border-radius: 20px; font-size: 0.85rem;">Ativo</span>
              {% else %}
                <span style="background-color: #ef4444; color: white; padding: 0.25rem 0.75rem; border-radius: 20px; font-size: 0.85rem;">Inativo</span>
              {% endif %}
            </td>
          </tr>
        {% else %}
          <tr>
            <td colspan="4" style="text-align: center; padding: 2rem;">Nenhum usuário encontrado.</td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
{% endblock %}
