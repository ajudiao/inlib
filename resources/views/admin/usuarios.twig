{% extends 'layouts/admin.twig' %}

{% block title %}Usuários - INLIB Admin{% endblock %}

{% block content %}
  <div class="admin-header">
    <h1>Gestão de Usuários</h1>
  </div>

  <div class="admin-header-actions" style="margin-bottom: 1rem;">
    <a href="{{ url('/admin/usuarios/adicionar-usuario') }}" class="btn-admin btn-admin-primary"><i class="fas fa-user-plus"></i> Novo Usuário</a>
  </div>

  {% if flash %}
    <div class="alert {% if flash.type == 'success' %}alert-success{% else %}alert-error{% endif %}">
      {{ flash.message }}
    </div>
  {% endif %}

  <div class="admin-toolbar">
    <form method="get" action="{{ url('/admin/usuarios') }}" class="search-form">
      <input type="text" name="q" value="{{ searchTerm|default('') }}" placeholder="Pesquisar por nome, email ou perfil">
      <button type="submit" class="btn-admin btn-admin-primary">Pesquisar</button>
      {% if searchTerm %}
        <a href="{{ url('/admin/usuarios') }}" class="btn-admin btn-admin-secondary">Limpar</a>
      {% endif %}
    </form>
  </div>

  <div class="table-container">
    <table>
      <thead>
        <tr>
          <th>Nome</th>
          <th>Email</th>
          <th>Perfil</th>
          <th>Status</th>
          <th>Ações</th>
        </tr>
      </thead>
      <tbody>
        {% for usuario in usuarios %}
          <tr>
            <td><strong>{{ usuario.nome }}</strong></td>
            <td>{{ usuario.email }}</td>
            <td>{{ usuario.perfil }}</td>
            <td>
              {% if usuario.ativo %}
                <span style="background-color: #10b981; color: white; padding: 0.25rem 0.75rem; border-radius: 20px; font-size: 0.85rem;">Ativo</span>
              {% else %}
                <span style="background-color: #ef4444; color: white; padding: 0.25rem 0.75rem; border-radius: 20px; font-size: 0.85rem;">Inativo</span>
              {% endif %}
            </td>
            <td>
              <div class="table-actions">
                <a href="{{ url('/admin/usuarios/editar/' ~ usuario.id) }}" class="table-action-btn action-edit">Editar</a>
                <form method="post" action="{{ url('/admin/usuarios/apagar/' ~ usuario.id) }}" onsubmit="return confirm('Tem a certeza que deseja apagar este usuário?');">
                  <button type="submit" class="table-action-btn action-delete">Apagar</button>
                </form>
              </div>
            </td>
          </tr>
        {% else %}
          <tr>
            <td colspan="5" style="text-align: center; padding: 2rem;">Nenhum usuário encontrado.</td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
{% endblock %}
