{% extends 'layouts/admin.twig' %}

{% block title %}Editar Categoria - INLIB Admin{% endblock %}

{% block content %}
  <div class="admin-header">
    <h1>Editar Categoria</h1>
    <a href="{{ url('/admin/categorias') }}" class="btn-admin btn-admin-secondary">Voltar à lista</a>
  </div>

  {% if flash %}
    <div class="alert {% if flash.type == 'success' %}alert-success{% else %}alert-error{% endif %}">
      {{ flash.message }}
    </div>
  {% endif %}

  <div class="form-container">
    <div class="form-card">
      <form action="{{ url('/admin/categorias/editar/' ~ categoria.id) }}" method="POST">
        <div class="form-section">
          <div class="form-section-header">
            <h3 class="form-section-title">Dados da Categoria</h3>
          </div>
          <div class="form-grid">
            <div class="form-group">
              <label for="nome">Nome *</label>
              <input type="text" id="nome" name="nome" value="{{ categoria.nome }}" required>
            </div>
            <div class="form-group">
              <label for="descricao">Descrição</label>
              <textarea id="descricao" name="descricao" rows="4">{{ categoria.descricao|default('') }}</textarea>
            </div>
          </div>
        </div>

        <div class="form-actions">
          <a href="{{ url('/admin/categorias') }}" class="btn-admin btn-admin-secondary">Cancelar</a>
          <button type="submit" class="btn-admin btn-admin-primary">Salvar Alterações</button>
        </div>
      </form>
    </div>
  </div>
{% endblock %}
