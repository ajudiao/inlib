{% extends 'layouts/admin.twig' %}

{% block title %}Adicionar Categoria - INLIB Admin{% endblock %}

{% block content %}
  <div class="admin-header">
    <h1>Adicionar Categoria</h1>
    <a href="{{ url('/admin/categorias') }}" class="btn-admin btn-admin-secondary">Voltar à lista</a>
  </div>

  {% if formError %}
    <div class="alert alert-error">{{ formError }}</div>
  {% endif %}

  {% if formSuccess %}
    <div class="alert alert-success">{{ formSuccess }}</div>
  {% endif %}

  {% if flash %}
    <div class="alert {% if flash.type == 'success' %}alert-success{% else %}alert-error{% endif %}">{{ flash.message }}</div>
  {% endif %}

  <div class="form-container" style="max-width: 900px;">
    <div class="form-card">
      <div class="form-section" style="margin-bottom: 0;">
        <div class="form-section-header">
          <h2 class="form-section-title">Nova categoria</h2>
          <p class="form-section-help">Crie uma categoria nova para organizar os livros da biblioteca.</p>
        </div>

        <form method="post" action="{{ url('/admin/categorias') }}">
          <div class="form-grid">
            <div class="form-group">
              <label for="categoria-nome">Nome *</label>
              <input id="categoria-nome" type="text" name="nome" value="{{ formOld.nome|default('') }}" required>
            </div>
            <div class="form-group">
              <label for="categoria-descricao">Descrição</label>
              <textarea id="categoria-descricao" name="descricao" rows="4">{{ formOld.descricao|default('') }}</textarea>
            </div>
          </div>

          <div class="form-actions" style="justify-content: flex-start; margin-top: 1.5rem; padding-top: 0; border-top: none;">
            <button type="submit" class="btn-admin btn-admin-primary">Salvar categoria</button>
            <a href="{{ url('/admin/categorias') }}" class="btn-admin btn-admin-secondary">Cancelar</a>
          </div>
        </form>
      </div>
    </div>
  </div>
{% endblock %}
