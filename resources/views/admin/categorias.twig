{% extends 'layouts/admin.twig' %}

{% block title %}Categorias - INLIB Admin{% endblock %}

{% block content %}
  <div class="admin-header">
    <h1>Gestão de Categorias</h1>
  </div>

  {% if formError %}
    <div class="alert alert-error">{{ formError }}</div>
  {% endif %}

  {% if formSuccess %}
    <div class="alert alert-success">{{ formSuccess }}</div>
  {% endif %}

  {% if flash %}
    <div class="alert {% if flash.type == 'success' %}alert-success{% else %}alert-error{% endif %}">{{ flash.message }}</div>
  {% endif %}

  <div style="background: #fff; padding: 1.25rem; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.08); margin-bottom: 1.5rem;">
    <h2 style="margin-top: 0; margin-bottom: 0.5rem;">Adicionar categoria</h2>
    <p style="margin-top: 0; color: #666;">O ID e a data de criação serão definidos automaticamente.</p>
    <form method="post" action="{{ url('/admin/categorias') }}">
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem;">
        <div>
          <label for="categoria-nome" style="display: block; margin-bottom: 0.35rem; font-weight: 600;">Nome</label>
          <input id="categoria-nome" type="text" name="nome" value="{{ formOld.nome|default('') }}" required style="width: 100%; padding: 0.7rem; border: 1px solid #ccc; border-radius: 6px;">
        </div>
        <div>
          <label for="categoria-descricao" style="display: block; margin-bottom: 0.35rem; font-weight: 600;">Descrição</label>
          <textarea id="categoria-descricao" name="descricao" rows="4" style="width: 100%; padding: 0.7rem; border: 1px solid #ccc; border-radius: 6px;">{{ formOld.descricao|default('') }}</textarea>
        </div>
      </div>
      <button type="submit" class="btn-admin btn-admin-primary">Salvar categoria</button>
    </form>
  </div>

  <div class="admin-toolbar">
    <form method="get" action="{{ url('/admin/categorias') }}" class="search-form">
      <input type="text" name="q" value="{{ searchTerm|default('') }}" placeholder="Pesquisar categorias">
      <button type="submit" class="btn-admin btn-admin-primary">Pesquisar</button>
      {% if searchTerm %}
        <a href="{{ url('/admin/categorias') }}" class="btn-admin btn-admin-secondary">Limpar</a>
      {% endif %}
    </form>
  </div>

  <div class="table-container">
    <table>
      <thead>
        <tr>
          <th>ID</th>
          <th>Nome</th>
          <th>Descrição</th>
          <th>Criado em</th>
          <th>Livros</th>
          <th>Ações</th>
        </tr>
      </thead>
      <tbody>
        {% for categoria in categories %}
          <tr>
            <td>{{ categoria.id }}</td>
            <td><strong>{{ categoria.nome }}</strong></td>
            <td>{{ categoria.descricao ?: 'Sem descrição' }}</td>
            <td>{{ categoria.criado_em ?: '—' }}</td>
            <td>{{ categoria.livros_count }}</td>
            <td>
              <div class="table-actions">
                <a href="{{ url('/admin/categorias/editar/' ~ categoria.id) }}" class="table-action-btn action-edit">Editar</a>
                <form method="post" action="{{ url('/admin/categorias/apagar/' ~ categoria.id) }}" onsubmit="return confirm('Tem a certeza que deseja apagar esta categoria?');">
                  <button type="submit" class="table-action-btn action-delete">Apagar</button>
                </form>
              </div>
            </td>
          </tr>
        {% else %}
          <tr>
            <td colspan="6" style="text-align: center; padding: 2rem;">Nenhuma categoria encontrada.</td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
{% endblock %}
