{% extends 'layouts/public.twig' %}

{% block title %}Sobre - INLIB{% endblock %}

{% block content %}
  <style>
    .page-hero {
      background: linear-gradient(135deg, var(--primary-dark) 0%, var(--primary-light) 100%);
      color: var(--white);
      padding: 4rem 0;
      text-align: center;
    }

    .page-hero h1 {
      color: var(--white);
      margin-bottom: 1rem;
    }

    .content-section {
      max-width: 900px;
      margin: 0 auto;
      padding: 0 1rem;
    }

    .content-block {
      margin: 4rem 0;
    }

    .content-block h2 {
      color: var(--primary-dark);
      margin-bottom: 1.5rem;
    }

    .content-block p {
      line-height: 1.8;
      color: var(--text-secondary);
      margin-bottom: 1rem;
    }

    .values-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 2rem;
      margin-top: 2rem;
    }

    .value-card {
      background-color: var(--gray-light);
      padding: 2rem;
      border-radius: var(--border-radius);
      text-align: center;
    }

    .value-icon {
      font-size: 2.5rem;
      margin-bottom: 1rem;
    }

    .value-card h3 {
      color: var(--primary-dark);
      margin-bottom: 1rem;
    }

    .value-card p {
      color: var(--text-secondary);
      margin: 0;
    }

    .team-section {
      background-color: var(--gray-light);
      padding: 3rem 0;
      margin: 4rem 0;
    }

    .team-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 2rem;
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 1rem;
    }

    .team-member {
      background-color: var(--white);
      padding: 1.5rem;
      border-radius: var(--border-radius);
      text-align: center;
      box-shadow: var(--box-shadow);
    }

    .member-avatar {
      width: 100px;
      height: 100px;
      background: linear-gradient(135deg, var(--primary-dark) 0%, var(--primary-light) 100%);
      border-radius: 50%;
      margin: 0 auto 1rem;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 2rem;
    }

    .team-member h4 {
      color: var(--text-primary);
      margin-bottom: 0.5rem;
    }

    .team-member p {
      font-size: 0.9rem;
      color: var(--text-secondary);
      margin: 0;
    }

    .timeline {
      max-width: 600px;
      margin: 2rem auto;
      position: relative;
      padding: 2rem 0;
    }

    .timeline-item {
      margin-bottom: 2rem;
      position: relative;
      padding-left: 3rem;
    }

    .timeline-item::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0;
      width: 20px;
      height: 20px;
      background-color: var(--primary-light);
      border-radius: 50%;
      border: 3px solid var(--white);
      box-shadow: 0 0 0 3px var(--primary-light);
    }

    .timeline-item h4 {
      color: var(--primary-dark);
      margin-bottom: 0.5rem;
    }

    .timeline-item p {
      color: var(--text-secondary);
      margin: 0;
    }

    @media (max-width: 768px) {
      .page-hero {
        padding: 2rem 0;
      }

      .team-grid {
        grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
      }

      .content-block {
        margin: 2rem 0;
      }
    }
  </style>

  <!-- Hero -->
  <section class="page-hero">
    <h1>Sobre INLIB</h1>
    <p>Conhecer nossa história e missão</p>
  </section>

  <!-- About Content -->
  <section class="section">
    <div class="content-section">
      <!-- Mission -->
      <div class="content-block">
        <h2>Nossa Missão</h2>
        <p>
          A INLIB (INSTIC LIBRARY) é uma biblioteca digital moderna criada com o objetivo de 
          democratizar o acesso ao conhecimento e à literatura. Nossa missão é proporcionar 
          uma plataforma intuitiva e segura onde leitores de todas as idades possam descobrir, 
          explorar e desfrutar de uma vasta coleção de livros.
        </p>
        <p>
          Acreditamos que a leitura é um direito fundamental e que toda pessoa deve ter acesso 
          a obras de qualidade, independentemente de sua localização geográfica ou situação econômica.
        </p>
      </div>

      <!-- Values -->
      <div class="content-block">
        <h2>Nossos Valores</h2>
        <div class="values-grid">
          <div class="value-card">
            <div class="value-icon"><i class="fas fa-book"></i></div>
            <h3>Conhecimento</h3>
            <p>Comprometidos em oferecer acesso ao melhor do conhecimento humano</p>
          </div>
          <div class="value-card">
            <div class="value-icon"><i class="fas fa-globe"></i></div>
            <h3>Inclusão</h3>
            <p>Cremos na democratização do acesso à literatura e educação</p>
          </div>
          <div class="value-card">
            <div class="value-icon"><i class="fas fa-shield-alt"></i></div>
            <h3>Segurança</h3>
            <p>Protegemos a privacidade e os dados de nossos usuários</p>
          </div>
          <div class="value-card">
            <div class="value-icon"><i class="fas fa-lightbulb"></i></div>
            <h3>Inovação</h3>
            <p>Utilizamos tecnologia de ponta para melhor experiência</p>
          </div>
        </div>
      </div>

      <!-- History -->
      <div class="content-block">
        <h2>Nossa História</h2>
        <div class="timeline">
          <div class="timeline-item">
            <h4>2024 - Início</h4>
            <p>Fundação da INLIB com visão de criar uma biblioteca digital moderna e acessível</p>
          </div>
          <div class="timeline-item">
            <h4>2024 - Lançamento Beta</h4>
            <p>Lançamento da plataforma com catálogo inicial de livros selecionados</p>
          </div>
          <div class="timeline-item">
            <h4>2024 - Crescimento</h4>
            <p>Expansão do catálogo e melhorias contínuas baseadas em feedback dos usuários</p>
          </div>
          <div class="timeline-item">
            <h4>2025+ - Futuro</h4>
            <p>Integração com sistemas mais avançados e expansão global da plataforma</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Team Section -->
  <section class="team-section">
    <div class="container">
      <h2 style="text-align: center; color: var(--primary-dark); margin-bottom: 2rem;">Equipe INLIB</h2>
      <div class="team-grid">
        <div class="team-member">
          <div class="member-avatar">👨‍💼</div>
          <h4>João Silva</h4>
          <p>Fundador & Diretor</p>
        </div>
        <div class="team-member">
          <div class="member-avatar">👩‍💻</div>
          <h4>Maria Santos</h4>
          <p>Desenvolvedora Sênior</p>
        </div>
        <div class="team-member">
          <div class="member-avatar">👨‍🎨</div>
          <h4>Pedro Oliveira</h4>
          <p>Designer UX/UI</p>
        </div>
        <div class="team-member">
          <div class="member-avatar">👩‍📚</div>
          <h4>Ana Costa</h4>
          <p>Curadora de Conteúdo</p>
        </div>
      </div>
    </div>
  </section>

  <script src="../../assets/js/main.js"></script>
{% endblock %}
