{% extends 'layouts/public.twig' %}

{% block title %}Pesquisa - INLIB{% endblock %}

{% block content %}
  <link rel="stylesheet" href="../../assets/css/home.css">
  <style>
    .search-hero {
      background: linear-gradient(135deg, var(--primary-dark) 0%, var(--primary-light) 100%);
      color: var(--white);
      padding: 3rem 0;
      text-align: center;
    }

    .search-hero h1 {
      color: var(--white);
      margin-bottom: 0.5rem;
    }

    .search-results {
      max-width: 1200px;
      margin: 3rem auto;
      padding: 0 1rem;
    }

    .results-info {
      margin-bottom: 2rem;
      padding: 1.5rem;
      background-color: var(--gray-light);
      border-radius: var(--border-radius);
    }

    .results-info h2 {
      color: var(--primary-dark);
      margin-bottom: 0.5rem;
    }

    .no-results {
      text-align: center;
      padding: 3rem;
    }

    .no-results h2 {
      color: var(--primary-dark);
      margin-bottom: 1rem;
    }

    .suggestion-links {
      display: flex;
      gap: 1rem;
      justify-content: center;
      flex-wrap: wrap;
      margin-top: 2rem;
    }
  </style>

  <!-- Search Hero -->
  <section class="search-hero">
    <div class="container">
      <h1>Resultados da Pesquisa</h1>
      <p id="search-term"></p>
    </div>
  </section>

  <!-- Results -->
  <section class="section">
    <div class="search-results">
      <div class="results-info">
        <h2 id="results-count">Carregando...</h2>
      </div>

      <div id="search-results-container" class="books-grid"></div>

      <div id="no-results" class="no-results" style="display: none;">
        <h2>Nenhum livro encontrado</h2>
        <p>Não encontramos livros que correspondam à sua pesquisa. Tente:</p>
        <ul style="text-align: left; display: inline-block; margin-top: 1rem;">
          <li>Verificar a ortografia</li>
          <li>Usar palavras-chave mais gerais</li>
          <li>Procurar por categoria</li>
        </ul>
        <div class="suggestion-links">
          <a href="{{ url('/livros') }}" class="btn btn-primary">Ver Todos os Livros</a>
          <a href="{{ url('/categorias') }}" class="btn btn-secondary">Explorar Categorias</a>
          <a href="{{ url('/') }}" class="btn btn-secondary">Voltar ao Início</a>
        </div>
      </div>
    </div>
  </section>

  <script src="../../assets/js/data.js"></script>
  <script src="../../assets/js/main.js"></script>
  <script>
    function performSearch() {
      const query = getUrlParameter('q');
      if (!query) {
        window.location.href = '/livros';
        return;
      }

      document.getElementById('search-term').textContent = `Resultados para: "${query}"`;
      document.title = `Pesquisa: ${query} - INLIB`;

      const results = searchBooks(query);
      const container = document.getElementById('search-results-container');
      const noResults = document.getElementById('no-results');
      const resultCount = document.getElementById('results-count');

      if (results.length === 0) {
        container.style.display = 'none';
        noResults.style.display = 'block';
        resultCount.textContent = 'Nenhum resultado encontrado';
      } else {
        container.style.display = 'grid';
        noResults.style.display = 'none';
        resultCount.innerHTML = `<strong>${results.length}</strong> livro${results.length !== 1 ? 's' : ''} encontrado${results.length !== 1 ? 's' : ''}`;
        renderBookCards(results, 'search-results-container');
      }
    }

    performSearch();
  </script>
{% endblock %}
