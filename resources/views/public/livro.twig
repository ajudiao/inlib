{% extends 'layouts/public.twig' %}

{% block title %}Livro - INLIB{% endblock %}

{% block content %}
  <style>
    .breadcrumb {
      max-width: 1200px;
      margin: 0 auto;
      padding: 1rem;
      font-size: 0.9rem;
      color: var(--text-secondary);
    }

    .breadcrumb a {
      color: var(--primary-light);
    }

    .book-detail-container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 2rem 1rem;
      display: grid;
      grid-template-columns: 300px 1fr;
      gap: 3rem;
    }

    .book-cover-section {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .book-cover-large {
      width: 100%;
      height: 450px;
      object-fit: cover;
      border-radius: var(--border-radius);
      box-shadow: var(--box-shadow-hover);
    }

    .book-actions {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .btn-read-pdf {
      width: 100%;
      padding: 1rem;
      background-color: var(--primary-light);
      color: var(--white);
      border: none;
      border-radius: var(--border-radius);
      cursor: pointer;
      font-weight: 600;
      font-size: 1rem;
      transition: var(--transition);
    }

    .btn-read-pdf:hover {
      background-color: var(--primary-dark);
      box-shadow: var(--box-shadow-hover);
    }

    .btn-add-favorite {
      width: 100%;
      padding: 1rem;
      background-color: var(--accent-blue);
      color: var(--white);
      border: none;
      border-radius: var(--border-radius);
      cursor: pointer;
      font-weight: 600;
      font-size: 1rem;
      transition: var(--transition);
    }

    .btn-add-favorite:hover {
      background-color: var(--primary-light);
    }

    .book-info-section h1 {
      color: var(--primary-dark);
      margin-bottom: 0.5rem;
    }

    .book-author-main {
      font-size: 1.25rem;
      color: var(--text-secondary);
      margin-bottom: 1rem;
    }

    .book-meta-main {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
      padding: 1.5rem;
      background-color: var(--gray-light);
      border-radius: var(--border-radius);
      margin-bottom: 2rem;
    }

    .meta-item {
      display: flex;
      flex-direction: column;
    }

    .meta-label {
      font-size: 0.85rem;
      color: var(--text-secondary);
      font-weight: 600;
      text-transform: uppercase;
      margin-bottom: 0.5rem;
    }

    .meta-value {
      font-size: 1rem;
      color: var(--text-primary);
      font-weight: 600;
    }

    .book-description-section h2 {
      color: var(--primary-dark);
      margin-top: 2rem;
      margin-bottom: 1rem;
    }

    .book-description-full {
      color: var(--text-secondary);
      line-height: 1.8;
      font-size: 1.05rem;
    }

    .category-badge-main {
      display: inline-block;
      background-color: var(--accent-blue);
      color: var(--white);
      padding: 0.5rem 1rem;
      border-radius: 20px;
      font-weight: 600;
      margin-bottom: 1.5rem;
    }

    .related-books-section {
      max-width: 1200px;
      margin: 4rem auto;
      padding: 0 1rem;
    }

    .related-books-section h2 {
      color: var(--primary-dark);
      margin-bottom: 2rem;
      text-align: center;
    }

    .related-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
      gap: 1.5rem;
    }

    @media (max-width: 768px) {
      .book-detail-container {
        grid-template-columns: 1fr;
        gap: 2rem;
      }

      .book-cover-large {
        height: 350px;
      }

      .book-meta-main {
        grid-template-columns: 1fr;
      }

      .related-grid {
        grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
      }
    }

    @media (max-width: 480px) {
      .book-detail-container {
        padding: 1rem;
      }

      .book-cover-large {
        height: 300px;
      }

      .related-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }
  </style>

  <!-- Breadcrumb -->
  <div class="breadcrumb">
    <a href="{{ url('/') }}">Início</a> > 
    <a href="{{ url('/livros') }}">Livros</a> > 
    <span id="breadcrumb-title">Carregando...</span>
  </div>

  <!-- Book Details -->
  <main class="book-detail-container">
    <!-- Cover Section -->
    <aside class="book-cover-section">
      <img id="book-cover" src="" alt="Capa do livro" class="book-cover-large">
      <div class="book-actions">
        <button class="btn-read-pdf" onclick="downloadPDF(getUrlParameter('id'))">
          📖 Ler PDF
        </button>
        <button class="btn-add-favorite" onclick="addToFavorite()">
          ❤️ Adicionar aos Favoritos
        </button>
      </div>
    </aside>

    <!-- Info Section -->
    <section class="book-info-section">
      <div class="category-badge-main" id="book-category">Categoria</div>
      <h1 id="book-title">Título do Livro</h1>
      <p class="book-author-main" id="book-author">Autor</p>

      <!-- Metadata -->
      <div class="book-meta-main">
        <div class="meta-item">
          <span class="meta-label">Editora</span>
          <span class="meta-value" id="book-publisher">-</span>
        </div>
        <div class="meta-item">
          <span class="meta-label">Ano</span>
          <span class="meta-value" id="book-year">-</span>
        </div>
        <div class="meta-item">
          <span class="meta-label">Páginas</span>
          <span class="meta-value" id="book-pages">-</span>
        </div>
        <div class="meta-item">
          <span class="meta-label">Idioma</span>
          <span class="meta-value" id="book-language">-</span>
        </div>
        <div class="meta-item">
          <span class="meta-label">ISBN</span>
          <span class="meta-value" id="book-isbn">-</span>
        </div>
        <div class="meta-item">
          <span class="meta-label">Categoria</span>
          <span class="meta-value" id="book-category-meta">-</span>
        </div>
      </div>

      <!-- Description -->
      <h2>Sobre este livro</h2>
      <p class="book-description-full" id="book-description">Descrição do livro.</p>
    </section>
  </main>

  <!-- Related Books -->
  <section class="related-books-section">
    <h2>Livros Relacionados</h2>
    <div id="related-books" class="related-grid"></div>
  </section>

  <script src="../../assets/js/data.js"></script>
  <script src="../../assets/js/main.js"></script>
  <script>
    function loadBookDetails() {
      const bookId = parseInt(getUrlParameter('id'));
      if (!bookId) {
        window.location.href = '{{ url('/livros') }}';
        return;
      }

      const book = getBook(bookId);
      if (!book) {
        alert('Livro não encontrado');
        window.location.href = '{{ url('/livros') }}';
        return;
      }

      // Update page title
      document.title = `${book.title} - INLIB`;

      // Update breadcrumb
      document.getElementById('breadcrumb-title').textContent = book.title;

      // Update book details
      document.getElementById('book-cover').src = book.cover;
      document.getElementById('book-cover').alt = book.title;
      document.getElementById('book-title').textContent = book.title;
      document.getElementById('book-author').textContent = `por ${book.author}`;
      document.getElementById('book-category').textContent = book.category;
      document.getElementById('book-category-meta').textContent = book.category;
      document.getElementById('book-publisher').textContent = book.publisher;
      document.getElementById('book-year').textContent = book.year;
      document.getElementById('book-pages').textContent = `${book.pages} páginas`;
      document.getElementById('book-language').textContent = book.language;
      document.getElementById('book-isbn').textContent = book.isbn;
      document.getElementById('book-description').textContent = book.description;

      // Load related books
      loadRelatedBooks(book.category, bookId);
    }

    function loadRelatedBooks(category, excludeId) {
      const related = getBooks(category)
        .filter(b => b.id !== excludeId)
        .slice(0, 4);
      
      renderBookCards(related, 'related-books');
    }

    function addToFavorite() {
      const bookId = parseInt(getUrlParameter('id'));
      const favorites = getStorage('favorites') || [];
      
      if (favorites.includes(bookId)) {
        const index = favorites.indexOf(bookId);
        favorites.splice(index, 1);
        showNotification('Removido dos favoritos', 'info');
      } else {
        favorites.push(bookId);
        showNotification('Adicionado aos favoritos!', 'success');
      }
      
      setStorage('favorites', favorites);
    }

    loadBookDetails();
  </script>
{% endblock %}
