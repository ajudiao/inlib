{% extends 'layouts/public.twig' %}

{% block title %}INLIB - Biblioteca Digital{% endblock %}

{% block content %}
  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-bg-panels">
      <div class="hero-bg-panel active"></div>
      <div class="hero-bg-panel"></div>
    </div>
    <div class="container">
      <div class="hero-content">
        <h1>Bem-vindo à INLIB</h1>
        <p>Descubra uma vasta coleção de livros digitais de qualidade e acesse o conhecimento em qualquer lugar.</p>
        <div class="hero-buttons">
          <a href="{{ url('/livros') }}" class="btn btn-primary">Explorar Livros</a>
          <a href="{{ url('/sobre') }}" class="btn btn-secondary">Saiba Mais</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Books -->
  <section class="featured-section">
    <div class="container">
      <div class="section-header">
        <h2>Livros em Destaque</h2>
        <p class="subtitle">Os melhores títulos para você começar a leitura</p>
      </div>
      <div class="books-grid">
        {% if featuredBooks is empty %}
          <p class="empty-message">Nenhum livro em destaque no momento.</p>
        {% else %}
          {% for book in featuredBooks %}
            <article class="book-card">
              <img src="{{ bookCover(book.capa) }}" alt="Capa de {{ book.titulo }}" class="book-cover" onerror="this.onerror=null;this.src='https://images.unsplash.com/photo-1507842217343-583bb7270b66?auto=format&fit=crop&w=500&q=80'">
              <div class="book-info">
                <h3 class="book-title">{{ book.titulo }}</h3>
                <p class="book-author">por {{ book.autor }}</p>
                <p class="book-meta">{{ book.editora|default('Editora não informada') }} • {{ book.anoPublicacao|default('Ano não informado') }}</p>
                <p class="book-description">{{ book.sinopse|default('Sinopse não disponível')|slice(0, 150) }}{% if book.sinopse|default('')|length > 150 %}…{% endif %}</p>
                <a href="{{ url('/ver_livro/' ~ book.id) }}" class="btn btn-secondary">Ver Detalhes</a>
              </div>
            </article>
          {% endfor %}
        {% endif %}
      </div>
      <div style="text-align: center; margin-top: 2rem;">
        <a href="{{ url('/livros') }}" class="btn btn-primary">Ver Todos os Livros</a>
      </div>
    </div>
  </section>

  <!-- Recent Books -->
  <section class="section section-light">
    <div class="container">
      <div class="section-header">
        <h2>Livros Recentes</h2>
        <p class="subtitle">As adições mais recentes da nossa biblioteca</p>
      </div>
      <div class="books-grid">
        {% if recentBooks is empty %}
          <p class="empty-message">Nenhum livro recente disponível.</p>
        {% else %}
          {% for book in recentBooks %}
            <article class="book-card">
              <img src="{{ bookCover(book.capa) }}" alt="Capa de {{ book.titulo }}" class="book-cover" onerror="this.onerror=null;this.src='https://images.unsplash.com/photo-1507842217343-583bb7270b66?auto=format&fit=crop&w=500&q=80'">
              <div class="book-info">
                <h3 class="book-title">{{ book.titulo }}</h3>
                <p class="book-author">por {{ book.autor }}</p>
                <p class="book-meta">{{ book.editora|default('Editora não informada') }} • {{ book.anoPublicacao|default('Ano não informado') }}</p>
                <p class="book-description">{{ book.sinopse|default('Sinopse não disponível')|slice(0, 150) }}{% if book.sinopse|default('')|length > 150 %}…{% endif %}</p>
                <a href="{{ url('/ver_livro/' ~ book.id) }}" class="btn btn-secondary">Ver Detalhes</a>
              </div>
            </article>
          {% endfor %}
        {% endif %}
      </div>
    </div>
  </section>

  <!-- Categories Preview -->
  <section class="categories-preview">
    <div class="container">
      <div class="section-header">
        <h2>Categorias</h2>
        <p class="subtitle">Explore nossos temas disponíveis</p>
      </div>
      <div class="categories-grid">
        {% for category in categoriesPreview %}
          <a class="category-card" href="{{ url('/livros') }}?category={{ category.nome|url_encode }}">
            <div class="category-name">{{ category.nome }}</div>
            <div class="category-count">{{ category.livros_count }} livros</div>
            <p class="category-description">{{ category.descricao|default('Descrição não disponível') }}</p>
          </a>
        {% endfor %}
      </div>
      <div style="text-align: center; margin-top: 2rem;">
        <a href="{{ url('/categorias') }}" class="btn btn-primary">Ver Mais Categorias</a>
      </div>
    </div>
  </section>

  <!-- Monographs Section -->
  <section class="section section-light">
    <div class="container">
      <div class="section-header">
        <h2>Monografias Destacadas</h2>
        <p class="subtitle">Trabalhos acadêmicos e pesquisas da universidade</p>
      </div>
      <div class="books-grid">
        {% if monographs is empty %}
          <p class="empty-message">Nenhuma monografia encontrada.</p>
        {% else %}
          {% for book in monographs %}
            <article class="book-card">
              <img src="{{ bookCover(book.capa) }}" alt="Capa de {{ book.titulo }}" class="book-cover" onerror="this.onerror=null;this.src='https://images.unsplash.com/photo-1507842217343-583bb7270b66?auto=format&fit=crop&w=500&q=80'">
              <div class="book-info">
                <h3 class="book-title">{{ book.titulo }}</h3>
                <p class="book-author">por {{ book.autor }}</p>
                <p class="book-meta">{{ book.editora|default('Editora não informada') }} • {{ book.anoPublicacao|default('Ano não informado') }}</p>
                <p class="book-description">{{ book.sinopse|default('Sinopse não disponível')|slice(0, 150) }}{% if book.sinopse|default('')|length > 150 %}…{% endif %}</p>
                <a href="{{ url('/ver_livro/' ~ book.id) }}" class="btn btn-secondary">Ver Detalhes</a>
              </div>
            </article>
          {% endfor %}
        {% endif %}
      </div>
      <div style="text-align: center; margin-top: 2rem;">
        <a href="{{ url('/livros') }}?category=Monografias" class="btn btn-primary">Ver Todas as Monografias</a>
      </div>
    </div>
  </section>

  <!-- Stats Section -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2>Por Números</h2>
        <p class="subtitle">Conheça nossa biblioteca</p>
      </div>
      <div class="stats-section">
        <div class="stat-card">
          <div class="stat-number">{{ totalBooks|default(0) }}</div>
          <div class="stat-label">Livros Catalogados</div>
        </div>
        <div class="stat-card">
          <div class="stat-number">{{ totalCategories|default(0) }}</div>
          <div class="stat-label">Categorias</div>
        </div>
        <div class="stat-card">
          <div class="stat-number">4</div>
          <div class="stat-label">Usuários Ativos</div>
        </div>
        <div class="stat-card">
          <div class="stat-number">12</div>
          <div class="stat-label">PDFs Disponíveis</div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta-section container">
    <h2>Pronto para começar?</h2>
    <p>Crie uma conta e acesse toda nossa coleção de livros</p>
    <a href="{{ url('/login') }}" class="btn btn-primary">Fazer Login</a>
  </section>

{% endblock %}
