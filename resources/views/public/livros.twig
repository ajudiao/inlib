{% extends 'layouts/public.twig' %}

{% block title %}Livros - INLIB{% endblock %}

{% block content %}
  <style>
    .page-header {
      background: linear-gradient(135deg, var(--primary-dark) 0%, var(--primary-light) 100%);
      color: var(--white);
      padding: 3rem 0;
      margin-bottom: 2rem;
    }

    .page-header h1 {
      color: var(--white);
      margin-bottom: 0.5rem;
    }

    .catalog-container {
      display: grid;
      grid-template-columns: 250px 1fr;
      gap: 2rem;
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 1rem;
    }

    .filters-sidebar {
      background-color: var(--gray-light);
      padding: 1.5rem;
      border-radius: var(--border-radius);
      height: fit-content;
      position: sticky;
      top: 100px;
    }

    .filter-group {
      margin-bottom: 2rem;
    }

    .filter-group h3 {
      font-size: 1rem;
      margin-bottom: 1rem;
      color: var(--primary-dark);
    }

    .filter-group label {
      display: flex;
      align-items: center;
      margin-bottom: 0.75rem;
      cursor: pointer;
      font-weight: normal;
    }

    .filter-group input[type="checkbox"] {
      margin-right: 0.5rem;
      cursor: pointer;
    }

    .filter-group input[type="text"] {
      width: 100%;
      padding: 0.5rem;
      margin-bottom: 0.5rem;
    }

    .clear-filters {
      width: 100%;
      padding: 0.75rem;
      background-color: var(--gray-medium);
      color: var(--text-primary);
      border: none;
      border-radius: var(--border-radius);
      cursor: pointer;
      font-weight: 600;
      transition: var(--transition);
    }

    .clear-filters:hover {
      background-color: var(--primary-light);
      color: var(--white);
    }

    .catalog-content {
      flex: 1;
    }

    .results-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 2rem;
      flex-wrap: wrap;
      gap: 1rem;
    }

    .results-count {
      color: var(--text-secondary);
    }

    .sort-select {
      padding: 0.5rem;
      border: 1px solid var(--gray-medium);
      border-radius: var(--border-radius);
      background-color: var(--white);
      cursor: pointer;
    }

    .pagination {
      display: flex;
      justify-content: center;
      gap: 0.5rem;
      margin-top: 2rem;
      flex-wrap: wrap;
    }

    .pagination button,
    .pagination a {
      padding: 0.5rem 0.75rem;
      border: 1px solid var(--gray-medium);
      background-color: var(--white);
      color: var(--primary-light);
      border-radius: 4px;
      cursor: pointer;
      transition: var(--transition);
      text-decoration: none;
    }

    .pagination button:hover,
    .pagination a:hover {
      background-color: var(--primary-light);
      color: var(--white);
    }

    .pagination .active {
      background-color: var(--primary-light);
      color: var(--white);
      border-color: var(--primary-light);
    }

    .pagination .disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }

    @media (max-width: 968px) {
      .catalog-container {
        grid-template-columns: 1fr;
      }

      .filters-sidebar {
        position: static;
      }

      .results-header {
        flex-direction: column;
        align-items: flex-start;
      }
    }

    @media (max-width: 768px) {
      .page-header {
        padding: 2rem 0;
      }

      .catalog-container {
        padding: 0 1rem;
      }

      .filters-sidebar {
        display: none;
      }
    }
  </style>

  <!-- Page Header -->
  <section class="page-header">
    <div class="container">
      <h1>Catálogo de Livros</h1>
      <p>Explore nossa coleção completa de títulos</p>
    </div>
  </section>

  <!-- Catalog -->
  <section class="section">
    <div class="catalog-container">
      <!-- Filters Sidebar -->
      <aside class="filters-sidebar">
        <h3>Filtros</h3>
        
        <div class="filter-group">
          <h3>Buscar</h3>
          <input type="text" id="search-input" placeholder="Digite aqui...">
        </div>

        <div class="filter-group">
          <h3>Categorias</h3>
          <div id="categories-filter"></div>
        </div>

        <div class="filter-group">
          <h3>Ano</h3>
          <label>
            <input type="checkbox" class="year-filter" value="2020-2024"> 2020-2024
          </label>
          <label>
            <input type="checkbox" class="year-filter" value="2010-2019"> 2010-2019
          </label>
          <label>
            <input type="checkbox" class="year-filter" value="2000-2009"> 2000-2009
          </label>
          <label>
            <input type="checkbox" class="year-filter" value="before2000"> Antes de 2000
          </label>
        </div>

        <button class="clear-filters" onclick="clearAllFilters()">Limpar Filtros</button>
      </aside>

      <!-- Books Catalog -->
      <main class="catalog-content">
        <div class="results-header">
          <span class="results-count" id="results-count">Carregando...</span>
          <select class="sort-select" id="sort-select" onchange="sortBooks()">
            <option value="title">Ordenar por Título</option>
            <option value="author">Ordenar por Autor</option>
            <option value="year-desc">Ano (Mais Recentes)</option>
            <option value="year-asc">Ano (Mais Antigos)</option>
          </select>
        </div>

        <div id="books-container" class="books-grid"></div>

        <div class="pagination" id="pagination"></div>
      </main>
    </div>
  </section>

  <script src="../../assets/js/main.js"></script>
  <script>
    const allBooks = {{ books|json_encode|raw }};
    const categoriesData = {{ categories|json_encode|raw }};
    let currentPage = 1;
    let filteredBooks = [...allBooks];
    const itemsPerPage = 9;
    let currentFilters = {
      search: '',
      categories: [],
      years: []
    };

    function initPage() {
      renderCategoryFilters();
      loadFromUrl();
      filterBooks();
      renderCatalog();
      attachEventListeners();
    }

    function renderCategoryFilters() {
      const container = document.getElementById('categories-filter');
      const categories = categoriesData;
      
      container.innerHTML = categories.map(cat => `
        <label>
          <input type="checkbox" class="category-filter" value="${cat.name}">
          ${cat.name}
        </label>
      `).join('');
    }

    function attachEventListeners() {
      document.getElementById('search-input').addEventListener('input', function() {
        currentFilters.search = this.value;
        currentPage = 1;
        filterBooks();
        renderCatalog();
      });

      document.querySelectorAll('.category-filter').forEach(checkbox => {
        checkbox.addEventListener('change', function() {
          if (this.checked) {
            currentFilters.categories.push(this.value);
          } else {
            currentFilters.categories = currentFilters.categories.filter(c => c !== this.value);
          }
          currentPage = 1;
          filterBooks();
          renderCatalog();
        });
      });

      document.querySelectorAll('.year-filter').forEach(checkbox => {
        checkbox.addEventListener('change', function() {
          if (this.checked) {
            currentFilters.years.push(this.value);
          } else {
            currentFilters.years = currentFilters.years.filter(y => y !== this.value);
          }
          currentPage = 1;
          filterBooks();
          renderCatalog();
        });
      });
    }

    function filterBooks() {
      filteredBooks = allBooks.filter(book => {
        let matches = true;

        // Search filter
        if (currentFilters.search) {
          const q = currentFilters.search.toLowerCase();
          matches = matches && (
            book.title.toLowerCase().includes(q) ||
            book.author.toLowerCase().includes(q)
          );
        }

        // Category filter
        if (currentFilters.categories.length > 0) {
          matches = matches && currentFilters.categories.includes(book.category);
        }

        // Year filter
        if (currentFilters.years.length > 0) {
          const year = book.year;
          matches = matches && currentFilters.years.some(range => {
            if (range === '2020-2024') return year >= 2020 && year <= 2024;
            if (range === '2010-2019') return year >= 2010 && year <= 2019;
            if (range === '2000-2009') return year >= 2000 && year <= 2009;
            if (range === 'before2000') return year < 2000;
            return false;
          });
        }

        return matches;
      });
    }

    function renderCatalog() {
      const result = paginate(filteredBooks, currentPage, itemsPerPage);
      
      // Update count
      document.getElementById('results-count').textContent = 
        `${filteredBooks.length} livro${filteredBooks.length !== 1 ? 's' : ''} encontrado${filteredBooks.length !== 1 ? 's' : ''}`;

      // Render books
      renderBookCards(result.items, 'books-container');

      // Render pagination
      renderPagination(result.totalPages, result.currentPage);
    }

    function renderPagination(totalPages, currentPage) {
      const container = document.getElementById('pagination');
      let html = '';

      // Previous button
      if (currentPage > 1) {
        html += `<button onclick="goToPage(${currentPage - 1})">← Anterior</button>`;
      } else {
        html += `<button class="disabled" disabled>← Anterior</button>`;
      }

      // Page numbers
      for (let i = 1; i <= totalPages; i++) {
        if (i === currentPage) {
          html += `<button class="active">${i}</button>`;
        } else {
          html += `<button onclick="goToPage(${i})">${i}</button>`;
        }
      }

      // Next button
      if (currentPage < totalPages) {
        html += `<button onclick="goToPage(${currentPage + 1})">Próximo →</button>`;
      } else {
        html += `<button class="disabled" disabled>Próximo →</button>`;
      }

      container.innerHTML = html;
    }

    function goToPage(page) {
      currentPage = page;
      renderCatalog();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function sortBooks() {
      const sort = document.getElementById('sort-select').value;
      
      switch(sort) {
        case 'title':
          filteredBooks.sort((a, b) => a.title.localeCompare(b.title, 'pt-BR'));
          break;
        case 'author':
          filteredBooks.sort((a, b) => a.author.localeCompare(b.author, 'pt-BR'));
          break;
        case 'year-desc':
          filteredBooks.sort((a, b) => b.year - a.year);
          break;
        case 'year-asc':
          filteredBooks.sort((a, b) => a.year - b.year);
          break;
      }

      currentPage = 1;
      renderCatalog();
    }

    function clearAllFilters() {
      currentFilters = {
        search: '',
        categories: [],
        years: []
      };
      currentPage = 1;

      document.getElementById('search-input').value = '';
      document.querySelectorAll('.category-filter, .year-filter').forEach(cb => cb.checked = false);

      filterBooks();
      renderCatalog();
    }

    function loadFromUrl() {
      const urlCategory = getUrlParameter('category');
      if (urlCategory) {
        currentFilters.categories = [urlCategory];
        document.querySelectorAll('.category-filter').forEach(cb => {
          if (cb.value === urlCategory) cb.checked = true;
        });
      }
    }

    initPage();
  </script>
{% endblock %}
