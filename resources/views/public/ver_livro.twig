{% extends 'layouts/public.twig' %}

{% block title %}{{ book.titulo }} - INLIB{% endblock %}

{% block content %}
  <style>
    .breadcrumb {
      max-width: 1200px;
      margin: 0 auto;
      padding: 1rem;
      font-size: 0.95rem;
      color: var(--text-secondary);
    }

    .breadcrumb a {
      color: var(--primary-light);
      text-decoration: none;
    }

    .book-detail-container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 2rem 1rem;
      display: grid;
      grid-template-columns: 320px 1fr;
      gap: 2.5rem;
    }

    .book-cover-large {
      width: 100%;
      min-height: 420px;
      object-fit: cover;
      border-radius: var(--border-radius);
      box-shadow: var(--box-shadow-hover);
    }

    .book-actions {
      display: grid;
      gap: 1rem;
      margin-top: 1.5rem;
    }

    .book-actions a {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      padding: 1rem 1.2rem;
      border-radius: var(--border-radius);
      font-weight: 600;
      border: none;
      cursor: pointer;
      transition: var(--transition);
      text-decoration: none;
      color: var(--white);
    }

    .btn-primary-alt {
      background-color: var(--primary-light);
    }

    .btn-primary-alt:hover {
      background-color: var(--primary-dark);
    }

    .btn-secondary-alt {
      background-color: var(--accent-blue);
    }

    .btn-secondary-alt:hover {
      background-color: var(--primary-light);
    }

    .book-info-section h1 {
      margin-bottom: 0.5rem;
      color: var(--primary-dark);
    }

    .book-author-main {
      font-size: 1.1rem;
      color: var(--text-secondary);
      margin-bottom: 1.5rem;
    }

    .category-badge {
      display: inline-block;
      background-color: var(--accent-blue);
      color: var(--white);
      padding: 0.5rem 1rem;
      border-radius: 999px;
      font-weight: 600;
      margin-bottom: 1.5rem;
    }

    .book-meta-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
      margin-bottom: 2rem;
    }

    .meta-card {
      padding: 1rem;
      background-color: var(--gray-light);
      border-radius: var(--border-radius);
    }

    .meta-label {
      display: block;
      font-size: 0.85rem;
      color: var(--text-secondary);
      margin-bottom: 0.35rem;
      font-weight: 700;
      text-transform: uppercase;
    }

    .meta-value {
      font-size: 1rem;
      color: var(--text-primary);
      font-weight: 600;
    }

    .book-description-section {
      margin-top: 2rem;
    }

    .book-description-section h2 {
      font-size: 1.6rem;
      color: var(--primary-dark);
      margin-bottom: 1rem;
    }

    .book-description-full {
      color: var(--text-secondary);
      line-height: 1.85;
      font-size: 1.05rem;
      white-space: pre-line;
    }

    @media (max-width: 768px) {
      .book-detail-container {
        grid-template-columns: 1fr;
      }

      .book-meta-grid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 480px) {
      .book-detail-container {
        padding: 1rem;
      }

      .book-cover-large {
        min-height: 320px;
      }
    }
  </style>

  <div class="breadcrumb">
    <a href="{{ url('/') }}">Início</a> ›
    <a href="{{ url('/livros') }}">Livros</a> ›
    <span>{{ book.titulo }}</span>
  </div>

  <main class="book-detail-container">
    <div>
      <img
        src="{{ book.capa is not empty ? book.capa : 'https://images.unsplash.com/photo-1512820790803-83ca734da794?auto=format&fit=crop&w=800&q=80' }}"
        alt="Capa de {{ book.titulo }}"
        class="book-cover-large"
      >

      <div class="book-actions">
        <a href="{{ url('/livros') }}" class="btn-primary-alt">← Voltar para Livros</a>
        <a href="{{ book.capa is not empty ? book.capa : 'https://images.unsplash.com/photo-1512820790803-83ca734da794?auto=format&fit=crop&w=800&q=80' }}" class="btn-secondary-alt" target="_blank" rel="noreferrer">Abrir Livro</a>
      </div>
    </div>

    <section class="book-info-section">
      <span class="category-badge">{{ categoryName }}</span>
      <h1>{{ book.titulo }}</h1>
      <p class="book-author-main">por {{ book.autor }}</p>

      <div class="book-meta-grid">
        <div class="meta-card">
          <span class="meta-label">Editora</span>
          <span class="meta-value">{{ book.editora ?: 'Não informada' }}</span>
        </div>
        <div class="meta-card">
          <span class="meta-label">Ano</span>
          <span class="meta-value">{{ book.anoPublicacao ?: 'Não informado' }}</span>
        </div>
        <div class="meta-card">
          <span class="meta-label">ISBN</span>
          <span class="meta-value">{{ book.isbn ?: 'Não informado' }}</span>
        </div>
        <div class="meta-card">
          <span class="meta-label">Quantidade em estoque</span>
          <span class="meta-value">{{ book.quantidadeEstoque }}</span>
        </div>
      </div>

      <div class="book-description-section">
        <h2>Descrição</h2>
        <p class="book-description-full">{{ book.sinopse ?: 'Nenhuma descrição disponível para este livro.' }}</p>
      </div>
    </section>
  </main>
{% endblock %}
