<header>
  <div class="header-container">
    <a href="{{ url('/') }}" class="logo">
      <div class="logo-box">I</div>
      <div>
        <div class="logo-text">INLIB</div>
        <div class="logo-subtitle">Instic Library</div>
      </div>
    </a>

    <div class="nav-wrapper">
      <nav>
        <ul>
          <li><a href="{{ url('/') }}">Início</a></li>
          <li><a href="{{ url('/livros') }}">Livros</a></li>
          <li><a href="{{ url('/categorias') }}">Categorias</a></li>
          <li><a href="{{ url('/sobre') }}">Sobre</a></li>
          <li><a href="{{ url('/contato') }}">Contato</a></li>
          {% if session.user_id is defined and session.user_id is not null %}
            {% if session.user_perfil in ['admin', 'bibliotecario'] %}
              <li><a href="{{ url('/admin') }}">Painel Admin</a></li>
            {% endif %}
            <li><a href="{{ url('/logout') }}">Sair</a></li>
          {% else %}
            <li><a href="{{ url('/login') }}">Login</a></li>
          {% endif %}
        </ul>
      </nav>

      <div class="search-box">
        <input type="text" placeholder="Pesquisar livros...">
        <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.35-4.35"></path>
        </svg>
      </div>

      <button class="menu-toggle" aria-label="Abrir menu" aria-expanded="false" type="button">
        <span class="menu-icon"></span>
      </button>
    </div>
  </div>
</header>
